<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>G-Scores Dashboard</title>

    <!-- Dùng Google Fonts: Rubik -->
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Dùng Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Thêm icon Bootstrap cho nút menu -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- Header Mobile - có icon menu hambergur -->
    <div class="mobile-header d-md-none text-white shadow-sm">
        <h4 class="m-0 fw-bold">G-Scores</h4>
        <button class="btn text-white fs-2 p-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMobile">
            <i class="bi bi-list"></i>
        </button>
    </div>

    <!-- Header Desktop -->
    <div class="header-top d-none d-md-block">
        G-Scores System
    </div>

    <div class="container-fluid">
        <div class="row">

             <!-- Sidebar cho Desktop -->
            <div class="col-md-2 sidebar d-none d-md-block">
                <div class="nav flex-column menu-links">
                    <span class="ps-4 pb-2 text-muted fw-bold" style="font-size: 20px;">Menu</span>
                    <a class="nav-link active" href="#" onclick="switchTab('search', this)">Search Scores</a>
                    <a class="nav-link" href="#" onclick="switchTab('top10', this)">Top 10 Group A</a>
                    <a class="nav-link" href="#" onclick="switchTab('reports', this)">Reports (Chart)</a>
                </div>
            </div>

            <!-- Sidebar cho Mobile - tích Offcanvas của boostrap, xử lý icon menu -->
            <div class="offcanvas offcanvas-start bg-light" tabindex="-1" id="sidebarMobile">
                <div class="offcanvas-header bg-mint text-white" style="background-color: #17c3b2;">
                    <h5 class="offcanvas-title fw-bold">Menu</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body sidebar p-0">
                    <div class="nav flex-column menu-links mt-3">
                        <a class="nav-link active" href="#" data-bs-dismiss="offcanvas" onclick="switchTab('search', this)">Search Scores</a>
                        <a class="nav-link" href="#" data-bs-dismiss="offcanvas" onclick="switchTab('top10', this)">Top 10 Group A</a>
                        <a class="nav-link" href="#" data-bs-dismiss="offcanvas" onclick="switchTab('reports', this)">Reports (Chart)</a>
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="col-md-10 px-md-4 mt-3 mt-md-0">
                
             <!-- TAB 1: Search Scores -->
                <section id="section-search">
                    <div class="custom-card">
                        <h5 class="card-title">User Registration</h5>
                        <label class="form-label text-muted">Registration Number</label>
                        <div class="d-flex gap-3">
                            <input type="text" id="sbd-input" class="form-control" placeholder="Enter registration number..." style="max-width: 300px;">
                            <button id="btn-search" class="btn btn-mint px-4">Submit</button>
                        </div>
                        
                        <!--THÊM MỚI: dòng báo lỗi bên dưới input -->
                        <div id="sbd-error-msg" class="text-danger mt-2" style="font-size: 13px; display: none;"></div>
                    </div>

                    <!-- Trang trí khu vực Placeholder bằng line art bãi biển nhìn bắt mắt ^ ^! -->   
                    <div id="placeholder-section" class="custom-card empty-state">

                        <!-- Dùng svg để vẽ -->
                        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                            <!-- Mặt trời -->
                            <circle cx="150" cy="50" r="20" fill="none" stroke="#a8e6cf" stroke-width="4"/>
                            <!-- Sóng biển -->
                            <path d="M 10 120 Q 50 80 100 120 T 190 120" fill="none" stroke="#17c3b2" stroke-width="4" stroke-linecap="round"/>
                            <path d="M 10 140 Q 50 100 100 140 T 190 140" fill="none" stroke="#a8e6cf" stroke-width="4" stroke-linecap="round"/>
                            <!-- Cây dừa -->
                            <path d="M 40 120 Q 30 70 40 40" fill="none" stroke="#17c3b2" stroke-width="4" stroke-linecap="round"/>
                            <path d="M 40 40 Q 20 50 10 60 M 40 40 Q 60 40 70 50 M 40 40 Q 30 20 40 10 M 40 40 Q 60 20 70 10" fill="none" stroke="#a8e6cf" stroke-width="4" stroke-linecap="round"/>
                        </svg>
                        <p>Detailed view of search scores here!</p>
                    </div>

                     <!-- Khu vực Kết quả (Chưa seacrh gì thì kq sẽ được ẩn) -->
                    <div id="result-section" class="custom-card" style="display: none;">
                        <h5 class="card-title">Detailed Scores</h5>
                        <div id="score-data" class="row text-center mt-4">
                            <!-- Nơi js đổ dữ liệu vào -->
                        </div>
                    </div>
                </section>

                <!-- TAB 2: Top 10 Group A -->
                <section id="section-top10" style="display: none;">
                    <div class="custom-card">
                        <h5 class="card-title">Top 10 Students - Group A</h5>
                        <div class="table-responsive">
                            <table class="table table-hover mt-3">
                                <thead class="table-light">
                                    <tr>
                                        <th>Rank</th>
                                        <th>SBD</th>
                                        <th>Toán</th>
                                        <th>Vật Lý</th>
                                        <th>Hóa Học</th>
                                        <th class="text-danger fw-bold">Tổng Điểm</th>
                                    </tr>
                                </thead>

                                <tbody id="top10-table-body">
                                    <!-- Nơi js đổ dữ liệu vào -->
                                </tbody>

                                <!--THÊM MỚI: thông báo chờ loading -->
                                <div id="loading-top10" class="text-center text-mint py-4" style="display: none;">
                                    <div class="spinner-border spinner-border-sm" role="status"></div>
                                    <span class="ms-2">Data retrieval will take a few seconds, please wait...</span>
                                </div>
                            </table>
                        </div>
                    </div>
                </section>

                <!-- TAB 3: Reports (Chart) -->
                <section id="section-reports" style="display: none;">
                    <div class="custom-card">
                        <h5 class="card-title">Score Statistics by Subjects</h5>
                        <!-- Bọc canvas để giới hạn chiều cao -->
                        <div style="height: 400px; width: 100%;">

                            <!--THÊM MỚI: thông báo chờ loading -->
                            <div id="loading-reports" class="text-center text-mint py-4" style="display: none;">
                                <div class="spinner-border spinner-border-sm" role="status"></div>
                                <span class="ms-2">Crunching numbers for 1 million records, please wait...</span>
                            </div>

                            <canvas id="scoreChart"></canvas>
                        </div>
                    </div>
                </section>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="/script.js"></script>

</body>
</html>